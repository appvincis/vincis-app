{
  "name": "Vincis-App",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel --loglevel silent",
    "build": "lerna run build",
    "start": "lerna run start --parallel",
    "dev::back": "cd apps/api && npm run dev",
    "dev::front": "cd apps/web && npm run dev"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/themes": "^4.5.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "lerna": "^9.0.7",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2"
  }
}
