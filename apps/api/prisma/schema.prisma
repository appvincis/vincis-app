generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  BASIC
  PREMIUM
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  supabaseId    String?   @unique
  plan          Plan      @default(BASIC)
  planExpiresAt DateTime? // null = plano basico, não expira

  studyPlans   StudyPlan[]
  errorLogs    ErrorLog[]
  editais      Edital[]
  aiSessions   AiSession[]
  FocusSession FocusSession[]
}

model StudyPlan {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int

  dailyMinutes  Int        @default(0)
  availableDays Int[]      @default([])
  targetDate    DateTime?
  srsMode       Boolean    @default(false)

  disciplines  Discipline[]
  errorLogs    ErrorLog[]
  FocusSession FocusSession[]
  editais      Edital[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Discipline {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  color       String
  weight      Float    @default(1.0)
  priority    Int      @default(3)
  knowledgeLevel Int   @default(1)
  isActive    Boolean  @default(true)
  studyPlanId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studyPlan    StudyPlan      @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  topics       Topic[]
  FocusSession FocusSession[]

  @@index([studyPlanId])
}

model Topic {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  isCompleted  Boolean  @default(false)
  disciplineId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discipline    Discipline     @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  errorLogs     ErrorLog[]
  focusSessions FocusSession[]

  @@index([disciplineId])
}

model ErrorLog {
  id Int @id @default(autoincrement())

  analise     String // "Por que eu errei?" — campo principal
  correcao    String? // "Resumo da Correção (Pulo do Gato)"
  fonte       String? // "Fonte da Questão" (ex: CESPE 2024 - PF)
  diagnostico String? // "Diagnóstico do Erro" (enum de 5 tipos)
  topicText   String? // "Tópico / Assunto" em texto livre

  isResolved Boolean   @default(false)
  resolvedAt DateTime?

  topicId Int?
  topic   Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  studyPlanId Int
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([studyPlanId])
  @@index([topicId])
}

model Edital {
  id            Int     @id @default(autoincrement())
  title         String
  description   String?
  fileUrl       String // Storage path, ex: `editais/${userId}/${filename}`
  fileSize      Int // In bytes
  parsedContent String? // Conteúdo de texto extraído do PDF
  parsedPages   Json?   // Mapa de páginas extraídas Record<number, string>
  pageRange     String? // Faixa de páginas do edital, ex: "25-35"

  // Cache do trecho de conteúdo programático já localizado — evita relocalização a cada extração
  syllabusChunk      String? // Texto do CP extraído e salvo após primeira localização
  syllabusChunkCargo String? // Cargo para o qual syllabusChunk foi extraído (null = geral)

  // Segmentos pré-parseados por disciplina — permite extração paralela e sem IA quando possível
  // Formato: [{name: string, rawText: string, topics?: string[], order: number}]
  syllabusSegments Json?

  extractionStatus   String  @default("PENDING") // PENDING, PROCESSING, READY_FOR_REVIEW, SUCCESS, FAILED
  extractionError    String?
  cargo              String?
  disciplinesCreated Int     @default(0)
  topicsCreated      Int     @default(0)

  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiSessions  AiSession[]

  studyPlanId Int?
  studyPlan   StudyPlan?  @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([studyPlanId])
}

model AiSession {
  id        String   @id @default(uuid())
  title     String   @default("Nova Conversa")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  editalId Int?
  edital   Edital? @relation(fields: [editalId], references: [id], onDelete: SetNull)

  messages AiMessage[]

  @@index([userId])
  @@index([editalId])
}

model AiMessage {
  id        String   @id @default(uuid())
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
  tokens    Int?

  sessionId String
  session   AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model FocusSession {
  id              Int        @id @default(autoincrement())
  duration        Int
  focusTime       Int
  breakTime       Int
  longBreakTime   Int
  cyclesTarget    Int
  cyclesCompleted Int
  isCompleted     Boolean    @default(false)
  startedAt       DateTime
  finishedAt      DateTime?

  // Campos de Relatório Pós-Sessão
  modalities       String[]  @default([])
  topicId          Int?
  questionsDone    Int       @default(0)
  questionsCorrect Int       @default(0)
  selfRating       Int?
  notes            String?

  disciplineId    Int
  studyPlanId     Int
  userId          Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  Discipline      Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  Topic           Topic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)
  StudyPlan       StudyPlan  @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  User            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studyPlanId])
  @@index([disciplineId])
  @@index([topicId])
}
