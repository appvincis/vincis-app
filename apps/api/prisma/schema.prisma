generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  BASIC
  PREMIUM
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String?
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  supabaseId    String?        @unique
  plan          Plan           @default(BASIC)
  planExpiresAt DateTime? // null = plano basico, não expira
  
  studyPlans    StudyPlan[]
  errorLogs     ErrorLog[]
  editais       Edital[]
  aiSessions    AiSession[]
  FocusSession  FocusSession[]
}

model StudyPlan {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  is_active   Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      Int
  
  disciplines Discipline[]
  errorLogs   ErrorLog[]
  FocusSession FocusSession[]
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discipline {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  color       String
  weight      Float     @default(1.0)
  isActive    Boolean   @default(true)
  studyPlanId Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  topics      Topic[]
  FocusSession FocusSession[]
}

model Topic {
  id           Int        @id @default(autoincrement())
  name         String
  description  String?
  isCompleted  Boolean    @default(false)
  disciplineId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  errorLogs    ErrorLog[]
}

model ErrorLog {
  id Int @id @default(autoincrement())

  analise     String // "Por que eu errei?" — campo principal
  correcao    String? // "Resumo da Correção (Pulo do Gato)"
  fonte       String? // "Fonte da Questão" (ex: CESPE 2024 - PF)
  diagnostico String? // "Diagnóstico do Erro" (enum de 5 tipos)
  topicText   String? // "Tópico / Assunto" em texto livre

  isResolved Boolean   @default(false)
  resolvedAt DateTime?

  topicId Int?
  topic   Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  studyPlanId Int
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Edital {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String // Storage path, ex: `editais/${userId}/${filename}`
  fileSize    Int // In bytes
  parsedContent String? // Conteúdo de texto extraído do PDF
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiSessions  AiSession[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiSession {
  id        String      @id @default(uuid())
  title     String      @default("Nova Conversa")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  editalId  Int?
  edital    Edital?     @relation(fields: [editalId], references: [id], onDelete: SetNull)
  
  messages  AiMessage[]
}

model AiMessage {
  id        String    @id @default(uuid())
  role      String    // "user" | "assistant"
  content   String
  createdAt DateTime  @default(now())
  tokens    Int?
  
  sessionId String
  session   AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model FocusSession {
  id              Int        @id @default(autoincrement())
  duration        Int
  focusTime       Int
  breakTime       Int
  longBreakTime   Int
  cyclesTarget    Int
  cyclesCompleted Int
  isCompleted     Boolean    @default(false)
  startedAt       DateTime
  finishedAt      DateTime?
  disciplineId    Int
  studyPlanId     Int
  userId          Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  Discipline      Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  StudyPlan       StudyPlan  @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  User            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
